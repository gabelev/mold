# Mold droplet environment. Installed to /etc/mold/mold.env (mode 0600).
# Loaded by every mold-* systemd unit via EnvironmentFile=.

# Paths
MOLD_ROOT=/opt/mold
MOLD_CONTENT_ROOT=/opt/mold/terrarium

# Model provider (unset = MockProvider; the pipeline runs offline)
# ANTHROPIC_API_KEY=
# MOLD_MODEL=claude-sonnet-5
# MOLD_MAX_TOKENS=4096

# Chaos Dimension ledger. CD_PUBLIC=1 reads the public feed with no
# credentials (the mold workstream is public); an agent token upgrades to
# authenticated reads AND enables writes (the surveyor's ledger drops).
CD_PUBLIC=1
# CD_AGENT_TOKEN=
# CD_API_URL=https://www.chaosdimension.fyi
# CD_WORKSTREAM=mold

# Promote qa -> prod after a successful publish (1 = yes)
MOLD_PROMOTE=0

# Optional webhook for heal/health notifications (ntfy topic, Slack hook, ...)
# MOLD_NOTIFY_URL=

# Staleness threshold for the watchdog, in hours (default 192 = 8 days)
MOLD_STALE_HOURS=192
